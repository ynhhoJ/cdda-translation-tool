{
  "name": "cdda-translation-tool",
  "version": "0.1.0",
  "description": "Universal translation management and QA tool for Cataclysm: Dark Days Ahead",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "extract": "bun run src/cli.ts extract",
    "commit-po": "bun run src/cli.ts commit-po",
    "sync-transifex": "bun run src/cli.ts sync-transifex",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "glob": "13.0.6"
  }
}

# Transifex API Configuration
# Copy this file to .env and fill in your values

# Required: Your Transifex API token
# Get it from: https://www.transifex.com/user/settings/api/
TRANSIFEX_API_TOKEN=your_api_token_here

# Required: Target language code (e.g. ru, de, fr, zh, ja)
TRANSIFEX_LANGUAGE=ru

# Optional: Override default Transifex project settings
# TRANSIFEX_ORG=cataclysm-dda-translators
# TRANSIFEX_PROJECT=cataclysm-dda
# TRANSIFEX_RESOURCE=master-cataclysm-dda
